{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matchbox.local/schemas/status.v1.json",
  "title": "Matchbox status (brain -> app)",
  "$defs": {
    "StatusJob": {
      "additionalProperties": false,
      "properties": {
        "job_id": {
          "minimum": 1,
          "type": "integer"
        },
        "cv_status": {
          "enum": [
            "pending",
            "running",
            "done",
            "skipped",
            "error"
          ],
          "type": "string"
        },
        "cover_status": {
          "enum": [
            "pending",
            "running",
            "done",
            "skipped",
            "error"
          ],
          "type": "string"
        },
        "cv_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cover_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "gaps": {
          "description": "Uncovered must-have requirements. Plain language.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "job_id",
        "cv_status",
        "cover_status"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Written and updated by the brain as it processes a run. The app file-watches this and re-renders the review screen on every change.",
  "properties": {
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$",
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "done",
        "error"
      ],
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Set only when status == 'error'. Human-readable."
    },
    "jobs": {
      "items": {
        "$ref": "#/$defs/StatusJob"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "status"
  ],
  "type": "object"
}
