{% set run_id = run_id if run_id is defined else run.id %}
<article
  id="job-card-{{ job.job_id }}"
  class="border border-border bg-surface rounded p-4"
  {% if job.cv_status not in ("done", "skipped", "error") or (job.want_cover and job.cover_status not in ("done", "skipped", "error")) %}
  hx-get="/review-run/{{ run_id }}/jobs/{{ job.job_id }}/card"
  hx-trigger="every 3s"
  hx-swap="outerHTML"
  {% endif %}
>
  <header class="flex items-start justify-between gap-3 mb-3">
    <div>
      <div class="font-semibold">{{ job.company }}</div>
      <div class="text-sm text-text-muted">{{ job.title }}</div>
    </div>
    <div class="text-right text-xs">
      <div>
        CV:
        {% if job.cv_status == "done" %}
          <span class="text-success">done</span>
        {% elif job.cv_status == "error" %}
          <span class="text-danger">error</span>
        {% elif job.cv_status in ("running",) %}
          <span class="text-warning">running…</span>
        {% else %}
          <span class="text-text-muted">{{ job.cv_status }}</span>
        {% endif %}
      </div>
      {% if job.want_cover %}
        <div>
          Cover:
          {% if job.cover_status == "done" %}
            <span class="text-success">done</span>
          {% elif job.cover_status == "error" %}
            <span class="text-danger">error</span>
          {% elif job.cover_status in ("running",) %}
            <span class="text-warning">running…</span>
          {% else %}
            <span class="text-text-muted">{{ job.cover_status }}</span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </header>

  {% if job.error %}
    <p class="text-xs text-danger mb-2">{{ job.error }}</p>
  {% endif %}

  {% if job.cv_status == "done" and job.cv_path %}
    <div class="mb-2 flex items-center gap-3 flex-wrap">
      <a class="text-xs text-accent underline" href="/runs/{{ run_id }}/output/{{ job.job_id }}/cv.pdf" target="_blank">
        Open CV PDF ↗
      </a>
      <form
        class="flex items-center gap-2 text-xs"
        hx-post="/review-run/{{ run_id }}/jobs/{{ job.job_id }}/restyle"
        hx-target="#job-card-{{ job.job_id }}"
        hx-swap="outerHTML"
      >
        <label>palette
          <select name="palette" class="border border-border rounded px-1 py-0.5 text-xs">
            {% for p in ["slate", "ink", "forest", "claret", "bronze"] %}
              <option value="{{ p }}" {% if p == job.palette %}selected{% endif %}>{{ p }}</option>
            {% endfor %}
          </select>
        </label>
        <label>font
          <select name="font" class="border border-border rounded px-1 py-0.5 text-xs">
            {% for f in ["source-serif", "source-sans", "inter", "atkinson-hyperlegible"] %}
              <option value="{{ f }}" {% if f == job.font %}selected{% endif %}>{{ f }}</option>
            {% endfor %}
          </select>
        </label>
        <button class="underline text-text-muted">Re-render</button>
      </form>
    </div>
    <iframe
      src="/runs/{{ run_id }}/output/{{ job.job_id }}/cv.pdf"
      class="w-full h-96 border border-border rounded"
      title="CV for {{ job.company }}"
    ></iframe>
  {% endif %}

  {% if job.gaps %}
    <details class="mt-3">
      <summary class="text-xs text-warning cursor-pointer">{{ job.gaps|length }} uncovered must-have{{ "" if job.gaps|length == 1 else "s" }}</summary>
      <ul class="mt-1 ml-4 text-xs text-text-muted list-disc">
        {% for g in job.gaps %}<li>{{ g }}</li>{% endfor %}
      </ul>
    </details>
  {% endif %}

  {% if job.notes %}
    <p class="text-xs text-text-muted mt-2">{{ job.notes }}</p>
  {% endif %}

  <footer class="mt-3 flex items-center gap-3 text-xs">
    <a
      class="bg-accent text-white rounded px-3 py-1"
      href="{{ job.apply_url or job.url }}"
      target="_blank"
      rel="noopener"
    >Apply ↗</a>
    {% if job.applied %}
      <span class="text-success">applied {{ job.applied.applied_at[:16] }}</span>
    {% else %}
      <form
        hx-post="/review-run/{{ run_id }}/jobs/{{ job.job_id }}/applied"
        hx-target="#job-card-{{ job.job_id }}"
        hx-swap="outerHTML"
      >
        <input type="hidden" name="cv_path" value="{{ job.cv_path or '' }}" />
        <input type="hidden" name="cover_path" value="{{ job.cover_path or '' }}" />
        <button class="underline text-text-muted">Mark applied</button>
      </form>
    {% endif %}
  </footer>
</article>
