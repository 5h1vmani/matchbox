{% extends "base.html.j2" %}
{% block title %}Sources · Matchbox{% endblock %}

{% block content %}
<section class="space-y-2 mb-6">
  <h1 class="text-xl font-semibold">Sources</h1>
  <p class="text-sm text-text-muted">
    Companies you want to track. Add a company, then scan to pull in new jobs.
    Failures stay visible so you can see exactly which source broke.
  </p>
</section>

<section class="mb-6 border border-border bg-surface rounded p-4">
  <h2 class="text-sm font-medium mb-2">Add a company</h2>
  <form
    class="grid grid-cols-5 gap-2 items-end"
    hx-post="/sources"
    hx-target="#sources-table tbody"
    hx-swap="beforeend"
    hx-on::after-request="if (event.detail.successful) this.reset()"
  >
    <label class="text-xs text-text-muted">
      ATS type
      <select class="block w-full border border-border rounded px-2 py-1 text-sm" name="ats_type" required>
        {% for t in ats_types %}<option value="{{ t }}">{{ t }}</option>{% endfor %}
      </select>
    </label>
    <label class="text-xs text-text-muted">
      Slug
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="slug" placeholder="e.g. anthropic" required />
    </label>
    <label class="text-xs text-text-muted">
      Company
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="company" placeholder="display name" required />
    </label>
    <label class="text-xs text-text-muted">
      Country (optional)
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="country" />
    </label>
    <button class="bg-accent text-white rounded px-3 py-1 text-sm">Add</button>
  </form>
  <div class="mt-2">
    <button
      class="text-xs text-text-muted underline"
      hx-post="/sources/probe"
      hx-include="closest section form"
      hx-target="#probe-result"
      hx-swap="outerHTML"
    >Test the slug</button>
    <span id="probe-result" class="text-xs"></span>
  </div>
</section>

<section class="mb-6">
  <button
    class="bg-accent text-white rounded px-3 py-1 text-sm"
    hx-post="/sources/scan-all"
    hx-target="#scan-summary"
    hx-swap="outerHTML"
    hx-indicator="#scan-indicator"
  >Scan all enabled</button>
  <span id="scan-indicator" class="htmx-indicator text-xs text-text-muted ml-2">scanning…</span>
  <div id="scan-summary"></div>
</section>

<section class="mb-6 border border-border bg-surface rounded p-4">
  <h2 class="text-sm font-medium mb-2">Remote &amp; aggregator sources</h2>
  <p class="text-xs text-text-muted mb-2">
    Pull remote roles from Himalayas and Remotive (no key needed). Add a free
    Adzuna key for broad full-time coverage including India.
  </p>
  <button
    class="bg-accent text-white rounded px-3 py-1 text-sm"
    hx-post="/sources/scan-remote"
    hx-target="#remote-scan-summary"
    hx-swap="outerHTML"
    hx-indicator="#remote-indicator"
  >Scan remote jobs</button>
  <span id="remote-indicator" class="htmx-indicator text-xs text-text-muted ml-2">scanning…</span>
  <div id="remote-scan-summary"></div>

  <form
    class="grid grid-cols-4 gap-2 items-end mt-3 pt-3 border-t border-border"
    hx-post="/sources/adzuna"
    hx-target="#adzuna-status"
    hx-swap="innerHTML"
  >
    <label class="text-xs text-text-muted">Adzuna app_id
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="app_id" value="{{ adzuna.app_id or '' }}" /></label>
    <label class="text-xs text-text-muted">Adzuna app_key
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="app_key" value="{{ adzuna.app_key or '' }}" /></label>
    <label class="text-xs text-text-muted">Country
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="country" value="{{ (adzuna.queries[0].country if adzuna.queries else 'in') }}" placeholder="in" /></label>
    <label class="text-xs text-text-muted">Keywords
      <input class="block w-full border border-border rounded px-2 py-1 text-sm" name="what" value="{{ (adzuna.queries[0].what if adzuna.queries else '') }}" placeholder="e.g. backend" /></label>
    <button class="bg-accent text-white rounded px-3 py-1 text-sm">Save Adzuna key</button>
    <span id="adzuna-status" class="text-xs col-span-3"></span>
  </form>
  <p class="text-[10px] text-text-muted mt-1">
    Free key at developer.adzuna.com. Results carry "Jobs by Adzuna" attribution.
  </p>
</section>

<section>
  <table id="sources-table" class="w-full text-sm border border-border bg-surface rounded">
    <thead class="bg-bg">
      <tr class="text-left text-xs text-text-muted">
        <th class="px-2 py-1">Company</th>
        <th class="px-2 py-1">ATS</th>
        <th class="px-2 py-1">Slug</th>
        <th class="px-2 py-1">Jobs</th>
        <th class="px-2 py-1">Status</th>
        <th class="px-2 py-1"></th>
      </tr>
    </thead>
    <tbody>
      {% for s in sources %}
        {% include "sources/_row.html.j2" with context %}
      {% endfor %}
    </tbody>
  </table>
  {% if not sources %}
    <p class="text-sm text-text-muted mt-3">No sources yet. Add one above.</p>
  {% endif %}
</section>
{% endblock %}
