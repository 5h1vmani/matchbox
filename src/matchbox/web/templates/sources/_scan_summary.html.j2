<div id="scan-summary" class="mt-3 border border-border bg-surface rounded p-3">
  <div class="text-sm">
    Scanned {{ results|length }} source{{ "" if results|length == 1 else "s" }}:
    <span class="text-success">{{ ok_count }} ok</span> ·
    <span class="text-danger">{{ fail_count }} failed</span> ·
    <span>{{ total_inserted }} new job{{ "" if total_inserted == 1 else "s" }}</span>.
  </div>
  <ul class="mt-2 space-y-1 text-xs">
    {% for r in results %}
      <li>
        {% if r.ok %}
          <span class="text-success">✓</span> {{ r.company }}/{{ r.slug }}:
          {{ r.fetched }} fetched, {{ r.inserted }} new
        {% else %}
          <span class="text-danger">✗</span> {{ r.company }}/{{ r.slug }}:
          <span class="text-text-muted">{{ r.error }}</span>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>
