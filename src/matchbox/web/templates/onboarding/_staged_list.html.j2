<div id="staged-list" class="space-y-1">
  {% if not staged %}
    <p class="text-xs text-text-muted">Nothing staged yet.</p>
  {% else %}
    <ul class="text-sm space-y-1">
      {% for f in staged %}
        <li id="staged-{{ f.name }}" class="flex items-center justify-between border border-border bg-surface rounded px-2 py-1">
          <span><code class="text-xs">{{ f.name }}</code> <span class="text-xs text-text-muted">({{ f.size }} bytes)</span></span>
          <button
            class="text-xs text-danger"
            hx-delete="/onboarding/staged/{{ f.name }}"
            hx-target="#staged-{{ f.name }}"
            hx-swap="outerHTML"
            hx-confirm="Remove this file from inbox/?"
          >Remove</button>
        </li>
      {% endfor %}
    </ul>
    <form
      class="mt-2"
      hx-post="/onboarding/clear"
      hx-target="#staged-list"
      hx-swap="outerHTML"
      hx-confirm="Clear all staged files?"
    >
      <button class="text-xs text-text-muted underline">Clear all</button>
    </form>
  {% endif %}
</div>
