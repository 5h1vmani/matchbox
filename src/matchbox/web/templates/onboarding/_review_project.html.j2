{% set p = tagged.item %}
<article id="review-project-{{ p.id }}" class="border border-border bg-surface rounded p-3 group">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1">
      <div class="font-medium">{{ p.name }}{% if p.url %} <a class="text-accent text-xs" href="{{ p.url }}" target="_blank" rel="noopener">↗</a>{% endif %}</div>
      <div class="text-sm text-text-muted">{{ p.text }}</div>
      <div class="mt-1 flex flex-wrap items-center gap-1">
        {% for t in tagged.tags %}
          <span class="chip"><span class="text-text-muted">{{ t.facet }}:</span>{{ t.value }}</span>
        {% endfor %}
      </div>
      <div class="mt-1 text-[10px]">
        {% if p.facts_verified %}<span class="text-success">verified</span>{% else %}<span class="text-warning">unverified</span>{% endif %}
      </div>
    </div>
    <div class="flex flex-col gap-1">
      {% if not p.facts_verified %}
        <button
          class="text-xs bg-success text-white rounded px-2 py-0.5"
          hx-post="/review/projects/{{ p.id }}/verify"
          hx-target="#review-project-{{ p.id }}"
          hx-swap="outerHTML"
        >Verify</button>
      {% endif %}
      <button
        class="text-xs text-danger opacity-0 group-hover:opacity-100 transition"
        hx-delete="/review/projects/{{ p.id }}"
        hx-target="#review-project-{{ p.id }}"
        hx-swap="outerHTML"
        hx-confirm="Delete this project?"
      >Delete</button>
    </div>
  </div>
</article>
