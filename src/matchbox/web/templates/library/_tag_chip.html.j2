{% set t = tag if tag is defined else t %}
<span id="tag-{{ item_type if item_type is defined else tagged.kind }}-{{ item_id if item_id is defined else tagged.item.id }}-{{ t.id }}" class="chip">
  <span class="text-text-muted">{{ t.facet }}:</span>{{ t.value }}
  <button
    type="button"
    aria-label="remove tag"
    hx-delete="/library/tags/{{ item_type if item_type is defined else tagged.kind }}/{{ item_id if item_id is defined else tagged.item.id }}/{{ t.id }}"
    hx-target="#tag-{{ item_type if item_type is defined else tagged.kind }}-{{ item_id if item_id is defined else tagged.item.id }}-{{ t.id }}"
    hx-swap="outerHTML"
  >×</button>
</span>
