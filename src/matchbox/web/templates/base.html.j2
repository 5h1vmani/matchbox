<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{% block title %}Matchbox{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg:           "#ffffff",
            surface:      "#ffffff",
            border:       "#e4e4e7",
            text:         "#09090b",
            "text-muted": "#696970",
            label:        "#52525b",
            accent:       "#52525b",
            success:      "#15803d",
            warning:      "#a16207",
            danger:       "#b91c1c",
          },
          fontFamily: {
            sans: ["IBM Plex Sans", "ui-sans-serif", "system-ui", "-apple-system", "sans-serif"],
            mono: ["IBM Plex Mono", "ui-monospace", "SFMono-Regular", "monospace"],
          },
        },
      },
    };
  </script>
  <style>
    @font-face {
      font-family: "IBM Plex Sans";
      font-weight: 400;
      font-style: normal;
      src: url("/static/fonts/IBMPlexSans-Regular.ttf") format("truetype");
    }
    @font-face {
      font-family: "IBM Plex Sans";
      font-weight: 600;
      font-style: normal;
      src: url("/static/fonts/IBMPlexSans-SemiBold.ttf") format("truetype");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-weight: 400;
      font-style: normal;
      src: url("/static/fonts/IBMPlexMono-Regular.ttf") format("truetype");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-weight: 600;
      font-style: normal;
      src: url("/static/fonts/IBMPlexMono-SemiBold.ttf") format("truetype");
    }
    body {
      font-family: "IBM Plex Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
      color: #3f3f46;
    }
    .chip {
      display: inline-flex; align-items: center; gap: 0.25rem;
      padding: 0.125rem 0.5rem; border-radius: 9999px;
      background: #f4f4f5; color: #52525b; font-size: 0.75rem;
      border: 1px solid #e4e4e7;
    }
    .chip button { color: #a1a1aa; }
    .chip button:hover { color: #b91c1c; }
  </style>
  <script>
    // Copy-to-clipboard: any element with data-copy="<selector>" copies
    // the textContent of the target on click and briefly shows feedback.
    document.addEventListener("click", function(e) {
      var btn = e.target.closest("[data-copy]");
      if (!btn) return;
      var sel = btn.getAttribute("data-copy");
      var src = document.querySelector(sel);
      if (!src || !navigator.clipboard) return;
      var text = (src.textContent || "").trim();
      navigator.clipboard.writeText(text).then(function() {
        var prev = btn.getAttribute("data-copy-original") || btn.textContent;
        btn.setAttribute("data-copy-original", prev);
        btn.textContent = "Copied";
        setTimeout(function() { btn.textContent = prev; }, 1200);
      }).catch(function() {
        btn.textContent = "Copy failed";
      });
    });
  </script>
</head>
<body class="bg-bg text-text">
  <header class="border-b border-border bg-surface">
    <div class="mx-auto max-w-5xl px-4 py-3 flex items-center gap-6">
      <a href="/library" class="font-semibold tracking-tight">Matchbox</a>
      <nav class="text-sm text-text-muted flex gap-4">
        <a href="/discover" class="hover:text-text">Discover</a>
        <a href="/tracker" class="hover:text-text">Applications</a>
        <a href="/inbox" class="hover:text-text">Inbox</a>
        <a href="/library" class="hover:text-text">Library</a>
        <a href="/review" class="hover:text-text">Review</a>
        <a href="/runs" class="hover:text-text">Runs</a>
        <a href="/sources" class="hover:text-text">Sources</a>
        <a href="/profile" class="hover:text-text">Profile</a>
        <a href="/targets" class="hover:text-text">Targets</a>
        <a href="/onboarding" class="hover:text-text">Onboarding</a>
      </nav>
    </div>
  </header>
  <main class="mx-auto max-w-5xl px-4 py-6">
    {% block content %}{% endblock %}
  </main>
</body>
</html>
