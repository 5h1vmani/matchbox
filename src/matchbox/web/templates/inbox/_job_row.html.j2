<tr id="job-{{ job.id }}" class="border-t border-border align-top">
  <td class="px-2 py-1 text-center">
    <input type="hidden" name="job_ids" value="{{ job.id }}" />
    <input type="checkbox" name="want_cv" value="{{ job.id }}" checked />
  </td>
  <td class="px-2 py-1 text-center">
    <input type="checkbox" name="want_cover" value="{{ job.id }}" />
  </td>
  <td class="px-2 py-1 text-xs font-mono">
    {% if job.score is not none %}
      {{ "%.2f"|format(job.score) }}
      {% if job.breakdown and job.breakdown.band %}
        <div class="mt-0.5 text-[10px] font-sans font-semibold uppercase tracking-wide
          {% if job.breakdown.band == 'strong' %}text-success
          {% elif job.breakdown.band == 'stretch' %}text-accent
          {% else %}text-text-muted{% endif %}">{{ job.breakdown.band }}</div>
      {% endif %}
    {% else %}
      —
    {% endif %}
  </td>
  <td class="px-2 py-1">
    <div class="font-medium">{{ job.company }}</div>
    <div class="text-xs">
      <a class="text-accent" href="{{ job.url }}" target="_blank" rel="noopener">{{ job.title }} ↗</a>
    </div>
  </td>
  <td class="px-2 py-1 text-xs text-text-muted">{{ job.location or "—" }}</td>
  <td class="px-2 py-1 text-xs">
    <div>{{ job.status }}</div>
    <div class="mt-1 flex gap-2">
      {% if job.status in ("skipped", "rejected") %}
        <button
          class="text-[10px] text-text-muted underline"
          hx-post="/inbox/jobs/{{ job.id }}/status"
          hx-vals='{"to": "scored"}'
          hx-target="#job-{{ job.id }}"
          hx-swap="outerHTML"
        >Re-open</button>
      {% else %}
        <button
          class="text-[10px] text-text-muted underline"
          hx-post="/inbox/jobs/{{ job.id }}/status"
          hx-vals='{"to": "skipped"}'
          hx-target="#job-{{ job.id }}"
          hx-swap="outerHTML"
          title="Skip for now"
        >Skip</button>
        <button
          class="text-[10px] text-danger underline"
          hx-post="/inbox/jobs/{{ job.id }}/status"
          hx-vals='{"to": "rejected"}'
          hx-target="#job-{{ job.id }}"
          hx-swap="outerHTML"
          title="Not interested"
        >Reject</button>
      {% endif %}
    </div>
  </td>
  <td class="px-2 py-1 text-xs text-text-muted">
    {% if job.breakdown %}
      <details>
        <summary class="cursor-pointer underline">why?</summary>
        <ul class="mt-1 space-y-0.5">
          {% for d in job.breakdown.dimensions %}
            <li>
              <code class="text-[10px]">{{ d.name }}</code>
              <span class="font-mono text-[10px]">{{ "%.2f"|format(d.score) }} × {{ "%.2f"|format(d.weight) }}</span>
              <span class="text-[10px]">— {{ d.reason }}</span>
            </li>
          {% endfor %}
        </ul>
      </details>
    {% endif %}
  </td>
</tr>
