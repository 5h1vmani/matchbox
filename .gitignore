archive/

# People profiles — real profiles are local-only.
# Only people/demo/ is committed. Any new directory is auto-ignored.
people/*
!people/README.md
!people/demo/
!people/demo/**
# Generated artifacts are never committed, even for demo.
people/demo/matchbox.db
people/demo/output/*
!people/demo/output/.gitkeep
people/*/matchbox.db
people/*/matchbox.db-*

# Brain-app handoff folders — derived state, never committed.
runs/*
!runs/.gitkeep

# Onboarding staging — user files, never committed.
inbox/*
!inbox/.gitkeep

# Embedding model cache (fastembed downloads weights on first use).
.fastembed_cache/

__pycache__/
*.pyc
*.pyo
.env
.venv/
.DS_Store
dist/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
