archive/

# People profiles — real profiles are local-only.
# Only people/demo/ is committed. Any new directory is auto-ignored.
people/*
!people/README.md
!people/demo/
!people/demo/**
# But never commit generated artifacts even for demo:
people/demo/db.sqlite
people/demo/output/*
!people/demo/output/.gitkeep
__pycache__/
*.pyc
*.pyo
.env
.venv/
.DS_Store
dist/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
