{% set s = tagged.item %}
<article id="skill-{{ s.id }}" class="border border-border bg-surface rounded p-3 group">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1">
      <div class="font-medium">{{ s.name }}{% if s.proficiency %} <span class="text-xs text-text-muted">({{ s.proficiency }})</span>{% endif %}</div>
      {% if s.category %}<div class="text-xs text-text-muted">{{ s.category }}</div>{% endif %}
      <div class="mt-1 flex flex-wrap items-center gap-1">
        {% for t in tagged.tags %}
          {% include "library/_tag_chip.html.j2" %}
        {% endfor %}
        <form
          class="inline-flex items-center gap-1"
          hx-post="/library/tags/skill/{{ s.id }}"
          hx-target="this"
          hx-swap="beforebegin"
          hx-on::after-request="if (event.detail.successful) this.reset()"
        >
          <select class="border border-border rounded text-xs px-1 py-0.5" name="facet">
            {% for f in facets %}<option value="{{ f }}">{{ f }}</option>{% endfor %}
          </select>
          <input class="border border-border rounded text-xs px-1 py-0.5 w-28" name="value" placeholder="tag…" list="tags-all" required />
          <button class="text-xs text-text-muted hover:text-text">+</button>
        </form>
      </div>
    </div>
    <button
      class="text-xs text-danger opacity-0 group-hover:opacity-100 transition"
      hx-delete="/library/skills/{{ s.id }}"
      hx-target="#skill-{{ s.id }}"
      hx-swap="outerHTML"
      hx-confirm="Delete this skill?"
    >Delete</button>
  </div>
</article>
